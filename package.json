{
  "name": "bali-arga-tour",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Premium Bali tour company profile — React + Vite + Tailwind + Framer Motion, SEO-first.",
  "scripts": {
    "dev": "vite",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "images:optimize": "node scripts/optimize-images.mjs",
    "clean": "node scripts/clean-dist.mjs",
    "prebuild": "node scripts/generate-sitemap.mjs",
    "build": "node scripts/clean-dist.mjs && vite-react-ssg build",
